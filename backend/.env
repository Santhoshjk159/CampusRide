NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database Configuration - MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=campus_ride_share
DB_PORT=3306

# JWT Configuration
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cookie Configuration
COOKIE_SECRET=replace_with_long_random_cookie_secret

# Security Configuration
CORS_ORIGIN=http://localhost:5173
SESSION_TIMEOUT=3600000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Email Configuration (if you plan to add email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@your-domain.com

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
